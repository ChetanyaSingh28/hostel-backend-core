# ============================
# Python Flask .gitignore
# ============================

# Virtual environment
.venv/
venv/
ENV/
env/

# Python bytecode / cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Environment variables (NEVER commit these)
.env
.env.local
.env.*.local

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/

# Distribution / packaging
*.tar.gz
*.whl
