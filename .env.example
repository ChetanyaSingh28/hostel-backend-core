# ==============================================
# Core Flask Backend – Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.

# ── Database ──────────────────────────────────
# Option A: Full connection URL (preferred for managed DBs like PlanetScale, Aiven, Railway)
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=mysql+pymysql://user:password@host:3306/hostel_system

# Option B: Individual credentials (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=hostel_system
DB_PORT=3306

# ── Auth ──────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Razorpay ──────────────────────────────────
RAZORPAY_KEY=rzp_test_XXXXXXXXXXXX
RAZORPAY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Email (Gmail App Password) ────────────────
EMAIL_USER=
EMAIL_PASS=

# ── Inter-service Communication ───────────────
# URL of the ML/AI classification backend
ML_API_URL=http://localhost:6000

# ── Frontend URL (used in password reset emails & CORS) ──
FRONTEND_URL=http://localhost:3000

# ── Flask ─────────────────────────────────────
FLASK_DEBUG=true
PORT=5000
